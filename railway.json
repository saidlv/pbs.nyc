{
    "$schema": "https://railway.app/railway.schema.json",
    "build": {
      "builder": "NIXPACKS",
      "nixpacksPlan": {
        "providers": ["php"],
        "phases": {
          "setup": {
            "nixPkgs": ["php82", "php82Packages.composer", "nodejs-18_x"],
            "aptPkgs": ["libxml2-dev", "libzip-dev", "unzip", "postgresql-client"]
          },
          "install": {
            "cmds": [
              "composer clear-cache",
              "composer install --no-dev --optimize-autoloader --prefer-dist --no-scripts"
            ]
          },
          "build": {
            "cmds": [
              "until pg_isready -h $PGHOST -p $PGPORT; do echo 'Waiting for PostgreSQL...'; sleep 2; done",
              "php artisan migrate --force",
              "php artisan key:generate --force",
              "php artisan optimize",
              "php artisan config:clear",
              "php artisan cache:clear"
            ]
          }
        }
      }
    },
    "deploy": {
      "startCommand": "php artisan serve --host=0.0.0.0 --port=$PORT"
    }
  }